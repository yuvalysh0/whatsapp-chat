# Copy to .env for local Docker: cp .env.example .env  (never commit .env)
# Production: set GEMINI_API_KEY in the host / compose secrets.
GEMINI_API_KEY=
PORT=3000
# Docker Compose: port on your Mac → app inside container still listens on 3000.
# Default in compose is 3080 to avoid “address already in use” on 3000.
HOST_PORT=3080
